# Required: Your Asana personal access token
ASANA_ACCESS_TOKEN=your_asana_personal_access_token_here

# Optional: Default Asana project ID (can be passed via route parameter instead)
# ASANA_PROJECT_ID=your_asana_project_id_here

# Optional: The GID of the Asana workspace (leave blank if not needed)
# ASANA_WORKSPACE_ID=

# Optional: Host address for the FastAPI/Uvicorn server (default: 127.0.0.1)
# APP_HOST=127.0.0.1

